# EngineeringDocs2LLM Configuration
# Copy this to .env and fill in your values

# Anthropic API Key (can also be entered in the web UI)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ODA File Converter path (optional, for DWG → DXF conversion)
# Download from: https://www.opendesign.com/guestfiles/oda_file_converter
# Windows example: ODA_PATH=C:\Program Files\ODA\ODAFileConverter\ODAFileConverter.exe
# Linux example:   ODA_PATH=/usr/bin/ODAFileConverter
# ODA_PATH=
